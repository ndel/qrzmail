# Marketing App Environment Variables
# Copy this file to .env and adjust values for your environment

# Base URL of the marketing app (used for tracking links, unsubscribe URLs)
BASE_URL=https://qrzmail.com

# Session secret for multi-user auth - MUST be set to a strong random value in production
# Must match the SESSION_SECRET used by the main QRZMail app if sharing sessions
SESSION_SECRET=replace-with-random-session-secret

# Data directory for SQLite database
MARKETING_DATA_DIR=./.data

# Worker polling interval in milliseconds (default: 10000)
MARKETING_POLL_INTERVAL=10000

# Batch size for queue processing (default: 50)
MARKETING_BATCH_SIZE=50

# IMAP bounce check interval in milliseconds (default: 60000)
MARKETING_IMAP_INTERVAL=60000
