MAILCOW_API_URL=https://mail.qrzmail.com
MAILCOW_API_KEY=replace-with-mailcow-api-key
MAIL_DOMAIN=qrzmail.com
SESSION_SECRET=replace-with-random-session-secret
QRZMAIL_DATA_DIR=/data
WEBMAIL_URL=https://mail.qrzmail.com/SOGo/
WEBMAIL_BASE_URL=https://mail.qrzmail.com/SOGo/so/
SOGO_CONNECT_URL=https://nginx-mailcow/SOGo/connect
IMAP_HOST=mail.qrzmail.com
IMAP_PORT=993
IMAP_SERVERNAME=mail.qrzmail.com

# Mailcow MySQL database — used to sync _sogo_static_view after password changes
# so SOGo can authenticate users with the new password immediately.
MAILCOW_DB_HOST=mysql-mailcow
MAILCOW_DB_PORT=3306
MAILCOW_DB_USER=mailcow
MAILCOW_DB_PASS=replace-with-mailcow-db-password
MAILCOW_DB_NAME=mailcow

# SMTP configuration for sending password reset emails
# 
# Option A (Docker internal relay — DEFAULT):
#   SMTP_HOST=postfix-mailcow
#   SMTP_PORT=25
#   SMTP_USER=   (leave empty)
#   SMTP_PASS=   (leave empty)
#   NOTE: postfix-mailcow may NOT relay to external addresses by default.
#   You may need to configure mailcow's postfix to allow relaying, or use Option B.
#
# Option B (External SMTP relay — RECOMMENDED for reliable delivery):
#   Examples: SendGrid, Mailgun, Amazon SES, or any SMTP service
#   SMTP_HOST=smtp.sendgrid.net
#   SMTP_PORT=587
#   SMTP_USER=apikey
#   SMTP_PASS=your-sendgrid-api-key
#   SMTP_FROM="QRZMail Support" <noreply@qrzmail.com>
#
SMTP_HOST=postfix-mailcow
SMTP_PORT=25
SMTP_USER=
SMTP_PASS=
SMTP_FROM="QRZMail Support" <noreply@qrzmail.com>
BASE_URL=https://qrzmail.com

# Cloudflare Turnstile — bot protection for signup
# Get your keys at https://dash.cloudflare.com/?to=/:account/turnstile
# TURNSTILE_SITE_KEY=0x4AAAAAAA... (public, used in frontend)
# TURNSTILE_SECRET_KEY=0x4AAAAAAA... (secret, used in backend)

# Debug mode — set to "true" to enable /api/debug/recovery endpoint
# WARNING: Only enable temporarily for troubleshooting, then disable!
# DEBUG_MODE=true
